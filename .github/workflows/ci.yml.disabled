name: CI

on:
  push:
    branches: ["**"]
  pull_request:
    branches: [main]

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  # ─────────────────────────────────────────────────────────────────────────────
  # Lint
  # ─────────────────────────────────────────────────────────────────────────────
  lint:
    name: Lint (ruff)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"
          cache: pip

      - name: Install ruff
        run: pip install "ruff>=0.9.0"

      - name: ruff check
        run: ruff check .

  # ─────────────────────────────────────────────────────────────────────────────
  # Smoke-import the core agent package
  # ─────────────────────────────────────────────────────────────────────────────
  smoke:
    name: Smoke import
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"
          cache: pip

      - name: Install minimal deps
        run: |
          pip install --upgrade pip
          # Install only the non-GPU, non-LLM deps needed for import-time checks
          pip install \
            requests httpx python-dotenv pyyaml typer \
            aiohttp aiofiles websockets

      - name: Verify agent module imports
        run: |
          python -c "from agent import context_engine, prompt_builder, model_metadata, logger"
          python -c "from gateway import config, hooks, delivery"
          echo "Import smoke passed"

  # ─────────────────────────────────────────────────────────────────────────────
  # Docker build validation (no push — proves the image builds on every PR)
  # ─────────────────────────────────────────────────────────────────────────────
  docker-build:
    name: Docker build
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Build (no push)
        uses: docker/build-push-action@v6
        with:
          context: .
          file: Dockerfile
          push: false
          # Export to local Docker daemon so we can run a quick healthcheck
          load: true
          tags: mercury:ci-${{ github.sha }}
          # Cache layers across runs via GitHub Actions cache backend
          cache-from: type=gha,scope=mercury-docker
          cache-to: type=gha,mode=max,scope=mercury-docker

      - name: Container smoke test
        run: |
          # Start container in detached mode with no API keys so it fails fast
          # but confirms the binary and entrypoint are healthy
          docker run --rm --name mercury-ci-smoke \
            -e MERCURY_UID=1001 -e MERCURY_GID=1001 \
            mercury:ci-${{ github.sha }} \
            python -c "from agent import model_metadata; print('OK')" \
            || true
          # Even if it fails, confirm the image built correctly
          docker inspect mercury:ci-${{ github.sha }} --format='{{.Config.Entrypoint}}' || true
